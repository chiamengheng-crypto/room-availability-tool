{
  "version": 2,
  "name": "room-availability",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/sync_data.json",
      "dest": "/sync_data.json"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}